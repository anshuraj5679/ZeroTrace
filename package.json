{
  "name": "zerotrace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network eth-sepolia",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "backend:dev": "npm --workspace backend run dev",
    "frontend:dev": "npm --workspace frontend run dev",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.0.13",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "cofhe-hardhat-plugin": "^0.3.1",
    "cofhejs": "^0.3.1",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.9",
    "patch-package": "^8.0.1"
  }
}
